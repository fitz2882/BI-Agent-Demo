# Google Gemini API Key (required)
GOOGLE_API_KEY=your-api-key-here

# SQLite database path (default: demo_data/demo.db)
DB_PATH=demo_data/demo.db

# Google File Search store name (optional)
# If set, the RetrievalAgent uses Google File Search for schema context.
# If not set, it falls back to the local SchemaProvider.
# Run: python scripts/upload_kb.py to create and populate the store.
GOOGLE_FILE_SEARCH_STORE=

# MAKER voting configuration
WORKER_BATCH_SIZE=3
MAX_RETRY_BATCHES=5
